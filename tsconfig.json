{
	"compilerOptions": {
		"esModuleInterop": true,
		"target": "es6",
		"module": "commonjs",
		"outDir": "./dist",
		"sourceMap": true,
		"noImplicitAny": true,
		"typeRoots": ["node_modules/@types", "./src/types"],
		"resolveJsonModule": true,
		// TODO enable this one by one file, for now it's fine for post.order.ts
		// "strictNullChecks": true
	},
	"include": ["./src/**/*", "./config/**/*"],
	"exclude": ["node_modules"]
}
